{
  "name": "@qyou/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "dev": "expo start",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/src/**/*.test.ts"],
    "moduleNameMapper": {
      "^@qyou/types$": "<rootDir>/../../packages/types/src/index.ts"
    }
  },
  "dependencies": {
    "expo": "~54.0.32",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5.9.3"
  }
}
