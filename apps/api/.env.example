PORT=4000

# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/qyou?schema=public"

# Secret used to sign access tokens. Use a long, random value in production.
JWT_SECRET="dev-secret-change-me"

# Access token lifetime (jsonwebtoken "expiresIn" format)
JWT_EXPIRES_IN="1h"
