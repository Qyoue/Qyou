{
  "name": "@qyou/stellar-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern='(challenge-verify|reward-account-readiness)' && node --import tsx/esm --test src/wallet-link.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "testPathIgnorePatterns": ["/node_modules/", "/dist/"],
    "extensionsToTreatAsEsm": [".ts"],
    "testPathIgnorePatterns": ["/node_modules/", "/dist/"],
    "moduleNameMapper": {
      "^@qyou/types$": "<rootDir>/../../packages/types/src/index.ts",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "useESM": true, "isolatedModules": true }]
    }
  },
  "dependencies": {
    "@qyou/config": "*",
    "@qyou/types": "*",
    "@stellar/stellar-sdk": "^14.3.3",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.0",
    "tsx": "^4.20.6"
  }
}
